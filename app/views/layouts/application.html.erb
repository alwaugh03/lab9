<!DOCTYPE html>
<html>
  <head>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <title><%= content_for(:title) || "Vet Clinic" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Vet Clinic">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application",
                               "data-turbo-track": "reload",
                               type: "module" %>
  </head>

  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
      <div class="container">
        <%= link_to "Vet Clinic", root_path, class: "navbar-brand" %>

        <div class="navbar-nav me-auto">
          <%= link_to "Owners", owners_path, class: "nav-link" %>
          <%= link_to "Pets", pets_path, class: "nav-link" %>
          <%= link_to "Vets", vets_path, class: "nav-link" %>
          <%= link_to "Appointments", appointments_path, class: "nav-link" %>
        </div>

        <div class="d-flex align-items-center gap-2">
          <% if user_signed_in? %>
            <span class="text-white me-2">
              <%= current_user.first_name %> <%= current_user.last_name %>
            </span>

            <%= button_to "Sign Out",
                          destroy_user_session_path,
                          method: :delete,
                          class: "btn btn-outline-light btn-sm" %>
          <% else %>
            <%= link_to "Sign In",
                        new_user_session_path,
                        class: "btn btn-outline-light btn-sm" %>

          <% end %>
        </div>
      </div>
    </nav>

    <div class="container">
      <%= render "layouts/flash" %>
      <%= yield %>
    </div>
  </body>
</html>