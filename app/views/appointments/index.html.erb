<div class="container mt-4">
  <h1 class="mb-4">Appointments</h1>
  <%= link_to "New Appointment", new_appointment_path, class: "btn btn-primary mb-3" %>
  <table class="table table-striped table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Date</th>
        <th>Pet</th>
        <th>Vet</th>
        <th>Reason</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @appointments.each do |appt| %>
        <tr>
          <td>
            <%= link_to appt.date.strftime("%B %d, %Y %H:%M"), appointment_path(appt), class: "text-decoration-none" %>
          </td>
          <td>
            <%= link_to appt.pet.name, pet_path(appt.pet) %>
          </td>
          <td>
            <%= link_to "#{appt.vet.first_name} #{appt.vet.last_name}", vet_path(appt.vet) %>
          </td>
          <td><%= appt.reason %></td>
          <td>
            <span class="badge 
              <%= case appt.status
                when "scheduled" then "bg-primary"
                when "in_progress" then "bg-warning"
                when "completed" then "bg-success"
                when "cancelled" then "bg-danger"
              end %>">
            <%= appt.status.humanize %>
          </span>
          </td>
          <td>
            <% if policy(appt).update? %>
              <%= link_to "Edit",
                    edit_appointment_path(appt),
                    class: "btn btn-sm btn-warning" %>
              <% end %>

              <% if policy(appt).destroy? %>
                <%= button_to "Delete",
                    appointment_path(appt),
                    method: :delete,
                    data: { turbo_confirm: "Are you sure?" },
                    class: "btn btn-sm btn-danger" %>
              <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
