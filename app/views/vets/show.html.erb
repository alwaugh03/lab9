<div class="container mt-4">
  <h1 class="mb-4">Vet Details</h1>

  <div class="card mb-4">
    <div class="card-body">
      <p><strong>Name:</strong> <%= @vet.first_name %> <%= @vet.last_name %></p>
      <p><strong>Email:</strong> <%= @vet.email %></p>
      <p><strong>Phone:</strong> <%= @vet.phone %></p>
      <p><strong>Specialization:</strong> <%= @vet.specialization %></p>
    </div>
  </div>

  <h3>Appointments</h3>
  <ul class="list-group">
    <% @vet.appointments.each do |appt| %>
      <li class="list-group-item">
        <%= link_to "#{appt.pet.name} - #{appt.date.strftime("%B %d, %Y %H:%M")}", appointment_path(appt) %>
      </li>
    <% end %>
  </ul>

  <h3>Past Appointments</h3>

  <table class="table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Pet</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @past_appointments.each do |appt| %>
        <tr>
          <td><%= appt.date.strftime("%B %d, %Y %H:%M") %></td>
          <td><%= appt.pet.name %></td>
          <td><%= appt.status.humanize %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if policy(@vet).update? %>
  <%= link_to "Edit",
      edit_vet_path(@vet),
      class: "btn btn-warning" %>
<% end %>

<% if policy(@vet).destroy? %>
  <%= button_to "Delete",
      vet_path(@vet),
      method: :delete,
      data: { turbo_confirm: "Are you sure?" },
      class: "btn btn-danger" %>
<% end %>