<div class="container mt-4">
  <h1 class="mb-4">Vets</h1>

  <%= form_with url: vets_path,
      method: :get,
      local: true,
      class: "mb-3" do %>

    <div class="row">
      <div class="col-md-4">
        <%= text_field_tag :specialization,
            params[:specialization],
            placeholder: "Search specialization...",
            class: "form-control" %>
      </div>

      <div class="col-md-2">
        <%= submit_tag "Filter",
            class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>

  <% if policy(Vet).create? %>
    <%= link_to "New Vet",
        new_vet_path,
        class: "btn btn-primary mb-3" %>
  <% end %>

  <table class="table table-striped table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Full Name</th>
        <th>Email</th>
        <th>Specialization</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @vets.each do |vet| %>
        <tr>
          <td>
            <%= link_to(
                  "#{vet.first_name} #{vet.last_name}",
                  vet_path(vet),
                  class: "text-decoration-none"
                ) %>
          </td>

          <td><%= vet.email %></td>
          <td><%= vet.specialization %></td>

          <td>
            <% if policy(vet).update? %>
              <%= link_to "Edit",
                  edit_vet_path(vet),
                  class: "btn btn-sm btn-warning" %>
            <% end %>

            <% if policy(vet).destroy? %>
              <%= button_to "Delete",
                    vet_path(vet),
                    method: :delete,
                    data: {
                      turbo_confirm: "Are you sure?"
                    },
                    class: "btn btn-sm btn-danger" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>