<div class="container mt-4">
  <h1 class="mb-4">Owners</h1>

  <% if policy(Owner).create? %>
    <%= link_to "New Owner",
        new_owner_path,
        class: "btn btn-primary mb-3" %>
  <% end %>

  <table class="table table-striped table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Full Name</th>
        <th>Email</th>
        <th>Phone</th>
        <th>Number of Pets</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @owners.each do |owner| %>
        <tr>
          <td>
            <%= link_to(
                  "#{owner.first_name} #{owner.last_name}",
                  owner_path(owner),
                  class: "text-decoration-none"
                ) %>
          </td>

          <td><%= owner.email %></td>
          <td><%= owner.phone %></td>
          <td><%= owner.pets.size %></td>

          <td>
            <% if policy(owner).update? %>
              <%= link_to "Edit",
                  edit_owner_path(owner),
                  class: "btn btn-sm btn-warning" %>
            <% end %>

            <% if policy(owner).destroy? %>
              <%= button_to "Delete",
                    owner_path(owner),
                    method: :delete,
                    data: {
                      turbo_confirm: "Are you sure?"
                    },
                    class: "btn btn-sm btn-danger" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>