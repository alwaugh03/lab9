<div class="container mt-4">
  <h1 class="mb-4">Pets</h1>

  <%= form_with url: pets_path,
      method: :get,
      local: true,
      class: "mb-3" do %>

    <div class="row">
      <div class="col-md-4">
        <%= select_tag :species,
            options_for_select(
              ["dog", "cat", "rabbit", "bird", "reptile", "other"],
              params[:species]
            ),
            include_blank: "All Species",
            class: "form-select" %>
      </div>

      <div class="col-md-2">
        <%= submit_tag "Filter",
            class: "btn btn-primary" %>
      </div>
    </div>
  <% end %>

  <% if policy(Pet).create? %>
    <%= link_to "New Pet",
        new_pet_path,
        class: "btn btn-primary mb-3" %>
  <% end %>

  <table class="table table-striped table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Photo</th>
        <th>Name</th>
        <th>Species</th>
        <th>Breed</th>
        <th>Owner</th>
        <th>Date of Birth</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @pets.each do |pet| %>
        <tr>
          <td>
            <% if pet.photo.attached? %>
              <%= image_tag(
                    pet.photo.variant(
                      resize_to_fill: [60, 60]
                    ),
                    class: "rounded"
                  ) %>
            <% else %>
              <div class="bg-light border rounded d-flex align-items-center justify-content-center"
                   style="width: 60px; height: 60px;">
                <small class="text-muted">
                  No photo
                </small>
              </div>
            <% end %>
          </td>

          <td>
            <%= link_to pet.name,
                pet_path(pet) %>
          </td>

          <td><%= pet.species %></td>
          <td><%= pet.breed %></td>

          <td>
            <%= pet.owner.first_name %>
            <%= pet.owner.last_name %>
          </td>

          <td>
            <%= pet.date_of_birth.strftime("%B %d, %Y") %>
          </td>

          <td>
            <% if policy(pet).update? %>
              <%= link_to "Edit",
                  edit_pet_path(pet),
                  class: "btn btn-sm btn-warning" %>
            <% end %>

            <% if policy(pet).destroy? %>
              <%= button_to "Delete",
                    pet_path(pet),
                    method: :delete,
                    data: {
                      turbo_confirm: "Are you sure?"
                    },
                    class: "btn btn-sm btn-danger" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>