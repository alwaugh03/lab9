<div class="container mt-4">
  <h1 class="mb-4">Pet Details</h1>

  <div class="card mb-4">
    <div class="card-body">
      <div class="row">
        
        <div class="col-md-4 text-center">
          <% if @pet.photo.attached? %>
            <%= image_tag @pet.photo,
                class: "img-fluid rounded mb-3",
                style: "max-height: 300px; object-fit: cover;" %>
          <% else %>
            <div class="border rounded p-4 text-center text-muted bg-light">
              No photo available
            </div>
          <% end %>
        </div>

        <div class="col-md-8">
          <p><strong>Name:</strong> <%= @pet.name %></p>
          <p><strong>Species:</strong> <%= @pet.species %></p>
          <p><strong>Breed:</strong> <%= @pet.breed %></p>
          <p><strong>Date of Birth:</strong> <%= @pet.date_of_birth.strftime("%B %d, %Y") %></p>
          <p><strong>Weight:</strong> <%= @pet.weight %></p>

          <p>
            <strong>Owner:</strong>
            <%= link_to "#{@pet.owner.first_name} #{@pet.owner.last_name}", owner_path(@pet.owner) %>
          </p>
        </div>

      </div>
    </div>
  </div>

  <h3>Appointments</h3>
  <ul class="list-group">
    <% @pet.appointments.each do |appt| %>
      <li class="list-group-item">
        <%= link_to appt.date.strftime("%B %d, %Y %H:%M"), appointment_path(appt) %>
      </li>
    <% end %>
  </ul>

  <h3>Upcoming Appointments</h3>
  <table class="table">
    <thead>
      <tr>
        <th>Date</th>
        <th>Vet</th>
        <th>Status</th>
      </tr>
    </thead>
    <tbody>
      <% @upcoming_appointments.each do |appt| %>
        <tr>
          <td><%= appt.date.strftime("%B %d, %Y %H:%M") %></td>
          <td><%= appt.vet.first_name %> <%= appt.vet.last_name %></td>
          <td><%= appt.status.humanize %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if policy(@pet).update? %>
  <%= link_to "Edit",
      edit_pet_path(@pet),
      class: "btn btn-warning" %>
<% end %>

<% if policy(@pet).destroy? %>
  <%= button_to "Delete",
      pet_path(@pet),
      method: :delete,
      data: { turbo_confirm: "Are you sure?" },
      class: "btn btn-danger" %>
<% end %>